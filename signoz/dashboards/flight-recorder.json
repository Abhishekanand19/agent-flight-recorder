      "opacity": "1",
      "softMax": 0,
      "softMin": 0,
      "stackedBarChart": false,
      "thresholds": [],
      "timePreferance": "GLOBAL_TIME",
      "yAxisUnit": "percentunit",
      "selectedLogFields": [],
      "selectedTracesFields": [],
      "query": {
        "id": "3f3f8b3a-0002-4a5b-9c1d-failurepanel",
        "queryType": "clickhouse_sql",
        "unit": "",
        "promql": [{ "name": "A", "query": "", "legend": "", "disabled": false }],
        "builder": {
          "queryData": [
            {
              "aggregations": [{ "expression": "count()" }],
              "dataSource": "traces",
              "disabled": true,
              "expression": "A",
              "filter": { "expression": "" },
              "functions": [],
              "groupBy": [],
              "having": { "expression": "" },
              "legend": "",
              "limit": null,
              "orderBy": [],
              "queryName": "A",
              "source": "",
              "stepInterval": null
            }
          ],
          "queryFormulas": [],
          "queryTraceOperator": []
        },
        "clickhouse_sql": [
          {
            "name": "A",
            "legend": "failure rate",
            "disabled": false,
            "query": "SELECT toStartOfInterval(timestamp, INTERVAL 5 MINUTE) AS ts, countIf(status_code_string = 'Error') / count() AS failure_rate FROM signoz_traces.distributed_signoz_index_v3 WHERE name LIKE 'tool.%' AND timestamp BETWEEN {{.start_datetime}} AND {{.end_datetime}} GROUP BY ts ORDER BY ts"
          }
        ]
      }
    },
    {
      "id": "replay-matrix",
      "title": "Replay success matrix (latest run per config)",
