              "source": "",
              "stepInterval": null
            }
          ],
          "queryFormulas": [],
          "queryTraceOperator": []
        },
        "clickhouse_sql": [
          {
            "name": "A",
            "legend": "",
            "disabled": false,
            "query": "SELECT attributes_string['replay.config_id'] AS config, argMax(attributes_string['replay.model'], timestamp) AS model, argMax(attributes_number['replay.temperature'], timestamp) AS temperature, argMax(attributes_bool['replay.fix_applied'], timestamp) AS fix_applied, argMax(attributes_bool['replay.success'], timestamp) AS success FROM signoz_traces.distributed_signoz_index_v3 WHERE name = 'replay_run' GROUP BY config ORDER BY config"
          }
        ]
      }
    },
