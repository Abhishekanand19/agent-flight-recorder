{
  "title": "Agent Flight Recorder",
  "description": "Token cost, failure rate, counterfactual replay matrix, and investigator confidence for the support agent.",
  "tags": ["flight-recorder", "hackathon"],
  "version": "v5",
  "panelMap": {},
  "variables": {},
  "layout": [
    { "i": "tokens-per-step", "x": 0, "y": 0, "w": 6, "h": 9, "moved": false, "static": false },
    { "i": "failure-rate", "x": 6, "y": 0, "w": 6, "h": 9, "moved": false, "static": false },
    { "i": "replay-matrix", "x": 0, "y": 9, "w": 6, "h": 9, "moved": false, "static": false },
    { "i": "investigator-confidence", "x": 6, "y": 9, "w": 6, "h": 9, "moved": false, "static": false },
    { "i": "top-failing-tools", "x": 0, "y": 18, "w": 12, "h": 8, "moved": false, "static": false }
  ],
  "widgets": [
    {
      "id": "tokens-per-step",
      "title": "LLM tokens per step (by service)",
      "description": "sum of llm.tokens on llm.chat spans; the token cost of every agent, replay, and investigation step",
      "panelTypes": "graph",
      "bucketCount": 30,
      "bucketWidth": 0,
      "columnUnits": {},
      "contextLinks": { "linksData": [] },
      "customLegendColors": {},
      "decimalPrecision": 2,
      "fillSpans": false,
      "isLogScale": false,
      "isStacked": false,
      "legendPosition": "bottom",
      "mergeAllActiveQueries": false,
      "nullZeroValues": "zero",
      "opacity": "1",
      "softMax": 0,
      "softMin": 0,
      "stackedBarChart": false,
      "thresholds": [],
      "timePreferance": "GLOBAL_TIME",
      "yAxisUnit": "none",
      "selectedLogFields": [],
      "selectedTracesFields": [],
      "query": {
        "id": "3f3f8b3a-0001-4a5b-9c1d-tokenspanel1",
        "queryType": "clickhouse_sql",
        "unit": "",
        "promql": [{ "name": "A", "query": "", "legend": "", "disabled": false }],
        "builder": {
          "queryData": [
            {
              "aggregations": [{ "expression": "count()" }],
              "dataSource": "traces",
              "disabled": true,
              "expression": "A",
              "filter": { "expression": "" },
              "functions": [],
              "groupBy": [],
              "having": { "expression": "" },
              "legend": "",
              "limit": null,
              "orderBy": [],
              "queryName": "A",
              "source": "",
              "stepInterval": null
            }
          ],
          "queryFormulas": [],
          "queryTraceOperator": []
        },
        "clickhouse_sql": [
          {
            "name": "A",
            "legend": "{{service}}",
            "disabled": false,
            "query": "SELECT toStartOfInterval(timestamp, INTERVAL 1 MINUTE) AS ts, `resource_string_service$$name` AS service, sum(attributes_number['llm.tokens']) AS tokens FROM signoz_traces.distributed_signoz_index_v3 WHERE name = 'llm.chat' AND timestamp BETWEEN {{.start_datetime}} AND {{.end_datetime}} GROUP BY ts, service ORDER BY ts"
          }
        ]
      }
    },
    {
      "id": "failure-rate",
      "title": "Agent tool failure rate",
      "description": "share of tool.* spans ending in ERROR",
      "panelTypes": "graph",
      "bucketCount": 30,
      "bucketWidth": 0,
      "columnUnits": {},
      "contextLinks": { "linksData": [] },
      "customLegendColors": {},
