        },
        "clickhouse_sql": [
          {
            "name": "A",
            "legend": "",
            "disabled": false,
            "query": "SELECT attributes_string['tool.name'] AS tool, countIf(status_code_string = 'Error') AS failures, count() AS calls, round(countIf(status_code_string = 'Error') / count(), 3) AS failure_rate FROM signoz_traces.distributed_signoz_index_v3 WHERE name LIKE 'tool.%' AND attributes_string['tool.name'] != '' GROUP BY tool ORDER BY failures DESC"
